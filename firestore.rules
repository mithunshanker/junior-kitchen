rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Helper: check if the requesting user is a delivery partner
    function isDelivery() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "delivery";
    }

    // Helper: check if user is admin or delivery
    function isStaff() {
      return isAdmin() || isDelivery();
    }

    // Users: own profile read/write; admin can read & write all; delivery can read all
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Menu: anyone can read (guest browsing); only admin can write
    match /menu/{dishId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: customers can only create their own order (userId must match auth uid).
    // Staff can read all. Only staff can update, but ONLY the status/delivery fields.
    match /orders/{orderId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || isStaff()
      );

      // Restrict update to only status tracking fields — prevents tampering with amount/items
      allow update: if isStaff()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'deliveredBy', 'deliveredByUid', 'updatedAt']);
    }

    // Sessions: each user manages their own; admin can read all
    match /sessions/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read: if isAdmin();
    }
  }
}
